# Copy to ".env" and fill in values:
#   cp env.example .env

# --- PostgreSQL (single server on localhost:5432) ---
# On many Macs the running server is the installer build under /Library/PostgreSQL/18
# (not Homebrew). Use the DB user + password that work in DBeaver — often user "postgres".
# Create the database once:
#   psql -U postgres -h localhost -d postgres -c "CREATE DATABASE cleverlocale;"
#
# Special characters in the password MUST be URL-encoded in DATABASE_URL, e.g.:
#   @ -> %40    # -> %23    % -> %25    : -> %3A    / -> %2F    ? -> %3F
# Or use a simple alphanumeric password for local dev only.
# If DBeaver uses user "vishwas" instead of "postgres", change USER below to match.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/cleverlocale?schema=public"
# After `git pull` changes Prisma schema, apply migrations to THIS database (local or Neon):
#   npx prisma migrate deploy

# --- Auth (Next.js / Auth.js) ---
# Required for login sessions. Generate once and keep stable (changing it logs everyone out).
#   openssl rand -base64 32
AUTH_SECRET="paste-output-from-openssl-here"
# Optional; helps callbacks in some setups. Alias: NEXTAUTH_URL
AUTH_URL="http://localhost:3000"
#
# Troubleshooting "can't log in":
# - Ensure AUTH_SECRET is set (same value after restarts). NEXTAUTH_SECRET also works.
# - Demo users must exist: npm run db:seed  →  admin1@… / vendor1@… / user1@… @cleverlocale.local  password cl@123
# - Emails are matched case-insensitively (stored lowercase).
