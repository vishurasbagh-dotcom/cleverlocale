// Cleverlocale — multi-vendor marketplace (INR, paise in DB)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  /// Submitted; awaiting admin review.
  PENDING
  /// Application paused / needs follow-up (admin).
  ON_HOLD
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vendor Vendor?
  cart   Cart?
  orders Order[]

  @@map("users")
}

model Vendor {
  id       String       @id @default(cuid())
  userId   String       @unique @map("user_id")
  shopName String       @map("shop_name")
  slug     String       @unique
  status   VendorStatus @default(PENDING)
  /// When false, shop and products are hidden from the public marketplace (vendor-controlled when approved).
  isShopOpen Boolean @default(true) @map("is_shop_open")
  /// When true, CL Admin has temporarily hidden the shop from the marketplace (vendor cannot edit until lifted).
  isAdminShopClosed Boolean @default(false) @map("is_admin_shop_closed")
  /// When true, CL Admin highlights this shop on /shops and prioritizes its products in homepage featured listings.
  isFeatured Boolean @default(false) @map("is_featured")
  /// Optional pitch / business description (not required for listing card).
  shopDescription String? @map("shop_description") @db.Text
  mobileNumber    String? @map("mobile_number")
  correctionNotes String? @map("correction_notes") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopLocation    VendorShopLocation?
  certificate     VendorCertificate?
  products          Product[]
  orderLines        OrderLine[]
  sellingCategories VendorSellingCategory[]

  @@index([status, isShopOpen])
  @@index([status, isFeatured])
  @@map("vendors")
}

/// Physical / mailing location and map coordinates for a vendor shop (1:1 with Vendor).
model VendorShopLocation {
  id           String   @id @default(cuid())
  vendorId     String   @unique @map("vendor_id")
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  locality     String?
  city         String?
  pincode      String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_shop_locations")
}

/// Uploaded verification document metadata (1:1 with Vendor; row exists only when a file is stored).
model VendorCertificate {
  id             String   @id @default(cuid())
  vendorId       String   @unique @map("vendor_id")
  storedName     String   @map("stored_name")
  originalName   String?  @map("original_name")
  mimeType       String?  @map("mime_type")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_certificates")
}

/// Categories this vendor intends to sell (application & admin review).
model VendorSellingCategory {
  vendorId   String @map("vendor_id")
  categoryId String @map("category_id")

  vendor   Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([vendorId, categoryId])
  @@index([categoryId])
  @@map("vendor_selling_categories")
}

model Category {
  id          String     @id @default(cuid())
  parentId    String?    @map("parent_id")
  name        String
  slug        String     @unique
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  products    Product[]
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    Category[] @relation("CategoryTree")
  vendorSellingCategories VendorSellingCategory[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id           String   @id @default(cuid())
  vendorId     String   @map("vendor_id")
  categoryId   String?  @map("category_id")
  name         String
  slug         String
  description  String?  @db.Text
  /// Price in Indian paise (1 INR = 100 paise). When `useVariantPricing` is true, this is unused for selling — use variant rows.
  pricePaise   Int      @map("price_paise")
  stock        Int      @default(0)
  isPublished  Boolean  @default(false) @map("is_published")
  /// Customer-facing name for option column 1 (e.g. Size, Storage).
  variantLabel1 String? @map("variant_label_1")
  /// Customer-facing name for option column 2 (e.g. Storage).
  variantLabel2 String? @map("variant_label_2")
  /// Third tier in nested options (e.g. Color / Finish).
  variantLabel3 String? @map("variant_label_3")
  /// When true, each `ProductVariant` row carries its own `pricePaise`; base `pricePaise` is ignored for checkout.
  useVariantPricing Boolean @default(false) @map("use_variant_pricing")
  /// When true, variant `color1`–`color3` swatches are shown; vendors can set them in the nested builder.
  useVariantColors Boolean @default(false) @map("use_variant_colors")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vendor     Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images     ProductImage[]
  variants   ProductVariant[]
  cartItems  CartItem[]
  orderLines OrderLine[]

  @@unique([vendorId, slug])
  @@index([categoryId])
  @@index([isPublished])
  @@map("products")
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String  @map("product_id")
  storedName String  @map("stored_name")
  sortOrder  Int     @default(0) @map("sort_order")
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String  @map("product_id")
  value1     String  @default("") @map("value_1")
  value2     String  @default("") @map("value_2")
  value3     String  @default("") @map("value_3")
  /// Optional display color (hex #RRGGBB) for tier 1 — shown when `product.useVariantColors` is true.
  color1     String? @map("color_1")
  /// Optional display color for tier 2.
  color2     String? @map("color_2")
  /// Optional display color for tier 3 (often the finish / color name row).
  color3     String? @map("color_3")
  /// Set when `product.useVariantPricing` is true; otherwise null and product `pricePaise` applies.
  pricePaise Int?    @map("price_paise")
  stock      Int     @default(0)
  sortOrder  Int     @default(0) @map("sort_order")
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderLines OrderLine[]

  @@unique([productId, value1, value2, value3])
  @@index([productId])
  @@map("product_variants")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String @map("cart_id")
  productId String @map("product_id")
  productVariantId String? @map("product_variant_id")
  quantity  Int

  cart           Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@index([cartId, productId])
  @@map("cart_items")
}

model Order {
  id         String      @id @default(cuid())
  userId     String      @map("user_id")
  status     OrderStatus @default(PENDING)
  /// Total copied at checkout (paise)
  totalPaise Int         @map("total_paise")
  currency   String      @default("INR")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lines OrderLine[]

  @@index([userId])
  @@map("orders")
}

model OrderLine {
  id             String @id @default(cuid())
  orderId        String @map("order_id")
  productId      String @map("product_id")
  vendorId       String @map("vendor_id")
  productVariantId String? @map("product_variant_id")
  /// Denormalized for receipts, e.g. "Size: M · Color: Navy"
  variantSummary String? @map("variant_summary") @db.Text
  productName    String @map("product_name")
  quantity       Int
  unitPaise      Int    @map("unit_paise")
  lineTotalPaise Int    @map("line_total_paise")

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([vendorId])
  @@map("order_lines")
}
